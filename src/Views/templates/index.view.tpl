<section class="hk-hero">
    <img src="/proyectogrupal/public/imgs/hero/hero1.jpeg" alt="Restaurante Hong Kong" class="hk-hero-bg"/>

    <div class="hk-hero-overlay">
        <h1>{{hero_title}}</h1>
        <p>{{hero_description}}</p>

        <div class="row flex-center my-3">
            <a href="{{login_url}}" class="hk-hero-btn mx-2">Iniciar Sesión</a>
            <a href="{{register_url}}" class="hk-hero-btn-outline mx-2">Crear Cuenta</a>
        </div>
    </div>
</section>

<section class="grid row py-5">
    <div class="col-12 center">
        <h3>{{welcome_title}}</h3>
        <p>{{welcome_description}}</p>
    </div>
</section>

<section class="grid row py-5">
    <div class="col-12 col-m-6 center">
        <div class="hk-info-box depth-0">
            <h4>{{schedule_title}}</h4>
            <p>{{schedule_description}}</p>
        </div>
    </div>
    <div class="col-12 col-m-6 center">
        <div class="hk-info-box depth-0">
            <h4>{{location_title}}</h4>
            <p>{{location_description}}</p>
        </div>
    </div>
</section>

<section class="grid row py-5">
    <div class="col-12 center">
        <h3>{{specialties_title}}</h3>
    </div>

    <div class="col-12 col-m-3 center">
        <div class="hk-specialty-box depth-0">
            <img src="/proyectogrupal/public/imgs/hero/camaronemp.jpeg" alt="Especialidad 1" class="hk-specialty-img" />
            <h4>{{specialty_1}}</h4>
            <p>{{specialty_1_desc}}</p>
        </div>
    </div>

    <div class="col-12 col-m-3 center">
        <div class="hk-specialty-box depth-0">
            <img src="/proyectogrupal/public/imgs/hero/polloagridulce.jpeg" alt="Especialidad 2" class="hk-specialty-img" />
            <h4>{{specialty_2}}</h4>
            <p>{{specialty_2_desc}}</p>
        </div>
    </div>

    <div class="col-12 col-m-3 center">
        <div class="hk-specialty-box depth-0">
            <img src="/proyectogrupal/public/imgs/hero/arrozcamaron.jpeg" alt="Especialidad 3" class="hk-specialty-img" />
            <h4>{{specialty_3}}</h4>
            <p>{{specialty_3_desc}}</p>
        </div>
    </div>

    <div class="col-12 col-m-3 center">
        <div class="hk-specialty-box depth-0">
            <img src="/proyectogrupal/public/imgs/hero/mixto.jpeg" alt="Especialidad 4" class="hk-specialty-img" />
            <h4>{{specialty_4}}</h4>
            <p>{{specialty_4_desc}}</p>
        </div>
    </div>
</section>

<section class="grid row py-5 center">
    <div class="col-12">
        <div class="hk-cta-box depth-0">
            <h3>{{cta_title}}</h3>
            <p>{{cta_description}}</p>
            <a href="{{cta_url}}" class="hk-hero-btn">Ordenar ahora</a>
        </div>
    </div>
</section>